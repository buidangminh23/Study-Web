      "answer": "Yes: (AB)C = A(BC)",
      "position": 7
    },
    {
      "title": "Result size",
      "prompt": "If A is 4×2 and B is 2×3, then AB has size:",
      "exercise_type": "multiple_choice",
      "options_json": [
        "4×3",
        "2×2",
        "4×2",
        "3×4"
      ],
      "answer": "4×3",
      "position": 8
    },
    {
      "title": "Subtraction",
      "prompt": "A − B can be computed as:",
      "exercise_type": "multiple_choice",
      "options_json": [
        "A + (−1)B",
